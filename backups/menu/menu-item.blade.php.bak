                    class="h-4 w-4 flex-shrink-0 transition-all duration-200 {{ $isOpen ? 'text-sky-600 dark:text-sky-400' : 'text-sky-500 group-hover:text-sky-600 dark:text-sky-500 dark:group-hover:text-sky-400' }}" />
                <span class="flex-1 text-left">{{ $menu->title }}</span>
                <svg
                    :class="open ? 'rotate-180 text-sky-500 dark:text-sky-400' : 'text-slate-400 group-hover:text-slate-500'"
                    class="h-3.5 w-3.5 flex-shrink-0 transition-all duration-200"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>

            <div x-show="open" x-collapse>
                <div class="space-y-0.5 py-0.5">
                    @foreach ($children as $child)
                        <x-menu.menu-item
                            :menu="$child"
                            :open-menus="$openMenus"
                            :level="$level + 1"
                            :collapsed="$collapsed" />
                    @endforeach
                </div>
            </div>
        @else
            <a
                href="{{ $href }}"
                @if ($href !== "#")
                    wire:navigate
                    @click="if (window.innerWidth < 768) { $dispatch('close-mobile-sidebar') }"
                @endif
                @class([
                    "group relative mx-3 flex w-[calc(100%-1.5rem)] items-center gap-2.5 rounded-lg px-3 py-2 text-xs font-medium transition-all duration-200",
