                    "text-slate-600 hover:bg-slate-100 hover:text-slate-800 dark:text-slate-400 dark:hover:bg-slate-800/60 dark:hover:text-slate-200" => ! $isActive,
                ])>
                @if (! $isActive)
                    <span
                        class="absolute inset-y-1.5 left-0 w-0.5 scale-y-0 rounded-r-full bg-sky-500 transition-transform duration-200 group-hover:scale-y-100"></span>
                @endif

                <x-menu.heroicon
                    name="{{ $menu->icon }}"
                    class="h-4 w-4 flex-shrink-0 transition-all duration-200 {{ $isActive ? 'text-sky-600 dark:text-sky-400' : 'text-sky-500 group-hover:text-sky-600 dark:text-sky-500 dark:group-hover:text-sky-400' }}" />
                <span>{{ $menu->title }}</span>
            </a>
        @endif
