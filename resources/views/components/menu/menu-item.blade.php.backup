@props([
    "menu",
    "openMenus" => [],
    "level" => 0,
    "collapsed" => false,
])

@php
    $children = $menu->childrenRecursive ?? collect();
    $hasChildren = $children->count() > 0;
    $isOpen = in_array($menu->id, $openMenus);
    $isActive = ! $hasChildren && $menu->route && \Illuminate\Support\Facades\Route::has($menu->route) && request()->routeIs($menu->route);

    $href = "#";
    if (! $hasChildren && $menu->route && \Illuminate\Support\Facades\Route::has($menu->route)) {
        try {
            $href = route($menu->route);
        } catch (Exception $e) {
        }
    }
@endphp

<div
    x-data="{
        open: @js($isOpen),
        menuId: {{ $menu->id }},
        hovering: false,
        collapsed: @js($collapsed),
        init() {
            this.$watch('$wire.openMenus', (value) => {
                const menus = Array.isArray(value)
                    ? value
                    : Object.values(value || {})
                this.open = menus.includes(this.menuId)
            })
            this.$watch('collapsed', (newVal, oldVal) => {
                if (newVal !== oldVal) {
                    this.hovering = false
                    if (newVal) {
                        this.open = false
                    }
                }
            })
        },
    }"
    x-init="
        $watch('$wire.collapsed', (value) => {
            collapsed = value
        })
    "
    wire:key="menu-item-{{ $menu->id }}-{{ $collapsed ? "collapsed" : "expanded" }}"
    class="relative">
    {{--
        ══════════════════════════════════════════════════════════════
        COLAPSADO — Solo icono centrado (aplica solo a nivel 0)
        ══════════════════════════════════════════════════════════════════
    --}}
    @if ($collapsed && $level === 0)
        @if ($hasChildren)
            <button
                x-ref="menuButton"
                x-on:click="open = !open; $dispatch('toggle-menu', {{ $menu->id }})"
                x-on:mouseenter="hovering = true"
                x-on:mouseleave="hovering = false"
                class="group relative flex w-full items-center justify-center py-1.5 transition-all duration-200"
                title="{{ $menu->title }}">
                <span
                    :class="open
                        ? 'bg-blue-600 text-white shadow-lg shadow-blue-200/50 dark:shadow-blue-900/40'
                        : 'text-blue-600 group-hover:text-blue-500 group-hover:drop-shadow-[0_0_5px_rgba(59,130,246,0.6)] dark:text-blue-400 dark:group-hover:text-blue-300'"
                    class="flex h-10 w-10 items-center justify-center rounded-xl transition-all duration-300 group-hover:scale-125">
                    <x-menu.heroicon name="{{ $menu->icon }}" class="h-6 w-6 shrink-0" />
                </span>
                <div
                    class="pointer-events-none absolute left-full z-50 ml-4 whitespace-nowrap rounded-lg bg-slate-900 px-3 py-2 text-[11px] font-bold uppercase tracking-wider text-white opacity-0 shadow-xl transition-all duration-200 group-hover:translate-x-1 group-hover:opacity-100">
                    {{ $menu->title }}
                </div>
            </button>

            {{-- Flyout --}}
            <div
                x-show="hovering"
                x-transition:enter="transition duration-200 ease-out"
                x-transition:enter-start="translate-x-4 scale-95 opacity-0"
                x-transition:enter-end="translate-x-0 scale-100 opacity-100"
                x-transition:leave="transition duration-150 ease-in"
                x-transition:leave-end="translate-x-4 scale-95 opacity-0"
                x-on:mouseenter="hovering = true"
                x-on:mouseleave="hovering = false"
                class="fixed z-[9999] w-64 overflow-hidden rounded-2xl border border-blue-100 bg-white/95 shadow-2xl backdrop-blur-sm dark:border-blue-900/50 dark:bg-slate-900/95"
                style="display: none"
                x-bind:style="`left: 5.5rem; top: ${$refs.menuButton ? $refs.menuButton.getBoundingClientRect().top - 10 : 0}px;`">
                <div
                    class="flex items-center gap-3 border-b border-blue-200 bg-blue-100/30 px-5 py-4 dark:border-blue-900/50 dark:bg-blue-950/60">
                    <span
                        class="flex h-8 w-8 items-center justify-center text-blue-600 transition-all duration-300 group-hover:scale-110 group-hover:text-blue-700 dark:text-blue-400">
                        <x-menu.heroicon name="{{ $menu->icon }}" class="h-6 w-6" />
                    </span>
                    <span class="text-xs font-bold uppercase tracking-wider text-blue-950 dark:text-blue-50">
                        {{ $menu->title }}
                    </span>
                </div>
                <div class="max-h-80 overflow-y-auto py-2">
                    @foreach ($children as $child)
                        @php
                            $flyChildHasChildren = ($child->childrenRecursive ?? collect())->count() > 0;
                            $flyHref = "#";
                            if (! $flyChildHasChildren && $child->route && \Illuminate\Support\Facades\Route::has($child->route)) {
                                try {
                                    $flyHref = route($child->route);
                                } catch (Exception $e) {
                                }
                            }
                        @endphp

                        @if ($flyChildHasChildren)
                            <div x-data="{ expanded: false }" class="px-2">
                                <button
                                    x-on:click="expanded = !expanded"
                                    :class="expanded
                                        ? 'bg-blue-50 text-blue-800 dark:bg-blue-900/40 dark:text-blue-200'
                                        : 'text-blue-700/80 hover:bg-blue-50/60 hover:text-blue-800 dark:text-blue-400/80 dark:hover:bg-blue-900/20 dark:hover:text-blue-300'"
                                    class="group relative flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-xs transition-all duration-300">
                                    {{-- Sin indicador vertical para opciones padre en flyout --}}

                                    <x-menu.heroicon
                                        name="{{ $child->icon }}"
                                        class="h-5 w-5 flex-shrink-0 text-blue-500 transition-all duration-300 group-hover:scale-110 group-hover:text-blue-600 dark:text-blue-400" />
                                    <span class="flex-1 text-left font-semibold">{{ $child->title }}</span>
                                    <svg
                                        :class="expanded ? 'rotate-180 text-blue-500' : 'text-slate-400 group-hover:text-blue-500'"
                                        class="h-3.5 w-3.5 transition-all duration-300"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2.5"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                <div x-show="expanded" x-collapse class="mt-1 space-y-1">
                                    @foreach ($child->childrenRecursive as $subChild)
                                        @php
                                            $subHref = "#";
                                            if ($subChild->route && \Illuminate\Support\Facades\Route::has($subChild->route)) {
                                                try {
                                                    $subHref = route($subChild->route);
                                                } catch (Exception $e) {
                                                }
                                            }
                                        @endphp

                                        <a
                                            href="{{ $subHref }}"
                                            @if ($subHref !== "#")
                                                wire:navigate
                                                x-on:click="if (window.innerWidth < 768) { $dispatch('close-mobile-sidebar') }"
                                            @endif
                                            @class([
                                                "group relative flex items-center gap-3 rounded-lg py-2 pl-8 pr-3 text-[11px] font-medium transition-all duration-300",
                                                "bg-blue-600 text-white shadow-md dark:shadow-none" => request()->url() === $subHref,
                                                "text-blue-600/70 hover:bg-blue-50/60 hover:text-blue-700 dark:text-blue-500/60 dark:hover:bg-blue-900/20 dark:hover:text-blue-400" => request()->url() !== $subHref,
                                            ])>
                                            <span class="flex-1">{{ $subChild->title }}</span>

                                            {{-- Punto indicador tipo online (derecha) --}}
                                            <div
                                                @class([
                                                    "h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.6)] transition-all duration-300",
                                                    "opacity-100 scale-100" => request()->url() === $subHref,
                                                    "opacity-0 scale-50 group-hover:opacity-100 group-hover:scale-100" => request()->url() !== $subHref,
                                                ])></div>
                                        </a>
                                    @endforeach
                                </div>
                            </div>
                        @else
                            <div class="px-2">
                                <a
                                    href="{{ $flyHref }}"
                                    @if ($flyHref !== "#")
                                        wire:navigate
                                        x-on:click="if (window.innerWidth < 768) { $dispatch('close-mobile-sidebar') }"
                                    @endif
                                    @class([
                                        "group relative flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-xs transition-all duration-300",
                                        "bg-blue-600 text-white shadow-md dark:shadow-none" => request()->url() === $flyHref,
                                        "text-blue-700/80 hover:bg-blue-50/60 hover:text-blue-800 dark:text-blue-400/80 dark:hover:bg-blue-900/20 dark:hover:text-blue-300" => request()->url() !== $flyHref,
                                    ])>
                                    <x-menu.heroicon
                                        name="{{ $child->icon }}"
                                        @class([
                                            "h-5 w-5 flex-shrink-0 transition-all duration-300 group-hover:scale-110",
                                            "text-white" => request()->url() === $flyHref,
                                            "text-blue-500 group-hover:text-blue-600 dark:text-blue-400" => request()->url() !== $flyHref,
                                        ]) />
                                    <span class="flex-1 font-semibold">{{ $child->title }}</span>

                                    {{-- Punto indicador tipo online (derecha) --}}
                                    <div
                                        @class([
                                            "h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.6)] transition-all duration-300",
                                            "opacity-100 scale-100" => request()->url() === $flyHref,
                                            "opacity-0 scale-50 group-hover:opacity-100 group-hover:scale-100" => request()->url() !== $flyHref,
                                        ])></div>
                                </a>
                            </div>
                        @endif
                    @endforeach
                </div>
            </div>
        @else
            <a
                href="{{ $href }}"
                @if ($href !== "#")
                    wire:navigate
                    x-on:click="if (window.innerWidth < 768) { $dispatch('close-mobile-sidebar') }"
                @endif
                x-on:mouseenter="hovering = true"
                x-on:mouseleave="hovering = false"
                class="group relative flex w-full items-center justify-center py-2 transition-all duration-300"
                title="{{ $menu->title }}">
                <span
                    @class([
                        "flex h-10 w-10 shrink-0 items-center justify-center rounded-xl transition-all duration-300 group-hover:scale-125",
                        "bg-blue-600 text-white shadow-lg shadow-blue-200/50 dark:shadow-blue-900/40" => $isActive,
                        "text-blue-600 group-hover:text-blue-500 group-hover:drop-shadow-[0_0_5px_rgba(59,130,246,0.6)] dark:text-blue-400 dark:group-hover:text-blue-300" => ! $isActive,
