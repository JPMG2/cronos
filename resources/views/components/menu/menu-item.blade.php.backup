                <span
                    class="flex h-8 w-8 flex-shrink-0 items-center justify-center transition-all duration-300"
                    :class="open
                    ? 'text-white'
                    : 'text-blue-600 group-hover:text-blue-500 group-hover:drop-shadow-[0_0_3px_rgba(59,130,246,0.5)] dark:text-blue-400 dark:group-hover:text-blue-300'">
                    <x-menu.heroicon name="{{ $menu->icon }}" class="h-4.5 w-4.5" />
                </span>
                <span class="flex-1 text-left uppercase tracking-wide">{{ $menu->title }}</span>
                <svg
