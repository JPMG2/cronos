                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
            </button>

            <div x-show="open" x-collapse>
                <div class="mt-1 space-y-1 py-1">
                    @foreach ($children as $child)
                        <x-menu.menu-item
                            :menu="$child"
                            :open-menus="$openMenus"
                            :level="1"
                            :collapsed="$collapsed" />
                    @endforeach
                </div>
            </div>
        @else
            <a
                href="{{ $href }}"
                @if ($href !== "#")
                    wire:navigate
                    x-on:click="if (window.innerWidth < 768) { $dispatch('close-mobile-sidebar') }"
                @endif
                @class([
                    "group relative mx-2.5 flex w-[calc(100%-1.25rem)] items-center gap-2.5 rounded-xl px-2.5 py-1.5 text-[11px] font-bold transition-all duration-300",
                    "bg-blue-600 text-white shadow-md shadow-blue-200/50 dark:shadow-blue-900/20" => $isActive,
                    "text-blue-700/80 hover:bg-blue-50/50 hover:text-blue-700 dark:text-blue-400/70 dark:hover:bg-blue-900/10 dark:hover:text-blue-300" => ! $isActive,
